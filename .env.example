# Copy this file to .env and fill in your credentials.
# Financial Modeling Prep now requires requests to use the stable endpoints.
# See https://financialmodelingprep.com/developer/docs for details.
FMP_API_KEY=YOUR_FMP_STABLE_API_KEY
FMP_BASE_URL=https://financialmodelingprep.com/stable
# Optional fallback base URL; leave empty to reuse the stable host
FMP_FALLBACK_BASE_URL=https://financialmodelingprep.com/stable
