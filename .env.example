# Copy this file to `.env` and fill in your credentials.
# Do NOT commit `.env` (it's listed in .gitignore).

# Required for Financial Modeling Prep (stable API)
FMP_API_KEY=YOUR_FMP_STABLE_API_KEY
FMP_BASE_URL=https://financialmodelingprep.com/stable
# Optional fallback base URL (leave empty to use the stable host)
FMP_FALLBACK_BASE_URL=https://financialmodelingprep.com/stable

# Which price provider to use by default: "yahoo_finance", "fmp", "local_repository"
# If you choose "fmp" you MUST set FMP_API_KEY above.
TS_PRICE_DATA_SOURCE=yahoo_finance

# Where to store local data (default: ./data)
TS_DATA_ROOT=./data

# Database connection (default: local SQLite)
DATABASE_URL=sqlite:///./trading_system.db

# Google Sheets (optional): path to service account JSON file used by Google Sheets integration
# If not using Google Sheets, you can leave this blank.
GOOGLE_CREDENTIALS_PATH=/app/config/credentials.json

# Kaggle (optional): credentials/config to enable the Kaggle dataset downloader (scripts/build_kaggle_price_db.py)
# You can use either KAGGLE_USERNAME/KAGGLE_KEY or set KAGGLE_CONFIG_DIR to point to a folder containing kaggle.json
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key
KAGGLE_CONFIG_DIR=~/.kaggle

# Logging and observability (optional)
LOG_LEVEL=INFO
# Optional Sentry DSN for error reporting
SENTRY_DSN=

# Notes:
# - Copy this file to `.env` and replace placeholder values with real credentials.
# - Keep `.env` out of version control and rotate secrets when leaked.
# - If you only use Yahoo (no API key required), you can leave FMP_API_KEY blank and set
#   TS_PRICE_DATA_SOURCE=yahoo_finance
